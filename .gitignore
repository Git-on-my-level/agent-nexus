.DS_Store

_src_core/
# Local dev-only encryption key for `make serve` (workspace secrets)
core/.anx-dev-secrets-key
core/.anx-dev-saas-ed25519
# Historical local paths (older CLI layouts); safe to delete locally
core/.oar-dev-secrets-key
core/.oar-dev-saas-ed25519
core/.oar-workspace/
core/.oar-control-plane/
# Local control-plane workspace for `make serve-control-plane` / dev-control-plane
core/.anx-control-plane/
# Regenerated when `make serve` seeds dev identities (contains invite tokens)
cli/dogfood-resources/*.generated.json
# Ad-hoc local `go build` outputs under cli/
cli/anx-dogfood
cli/anx-dogfood-bin
_src_ui/
_ui_working_tree.patch

.secrets/
# Local CLI import/scan output (any depth; un-ignore only if a path must be vendored on purpose)
.anx-import/
**/.anx-import/
.desloppify/
.superset/

# Cursor debug-session NDJSON (local only)
.cursor/debug-*.log
