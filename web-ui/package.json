{
  "name": "agent-nexus-ui",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "bash scripts/dev",
    "build": "vite build && node scripts/check-client-bundle.mjs",
    "preview": "vite preview",
    "qa:baseline": "node scripts/qa-capture.mjs --baseline",
    "qa:diff": "node scripts/qa-visual.mjs --diff",
    "lint": "eslint . && node scripts/check-svelte5-runes.js && node scripts/check-topic-create-call-sites.mjs && prettier --check \"src/**/*.{js,svelte,css}\" \"tests/**/*.js\" \"*.{json,js,cjs}\" \".github/workflows/*.yml\"",
    "format": "prettier --write \"src/**/*.{js,svelte,css}\" \"tests/**/*.js\" \"*.{json,js,cjs}\" \".github/workflows/*.yml\"",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "pnpm run lint && pnpm run test:unit && pnpm run test:e2e"
  },
  "dependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.5.18",
    "isomorphic-dompurify": "^3.6.0",
    "marked": "^17.0.4",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.22.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@playwright/test": "^1.51.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/svelte": "^5.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^16.0.0",
    "jsdom": "^29.0.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.14",
    "vitest": "^2.1.9"
  }
}
