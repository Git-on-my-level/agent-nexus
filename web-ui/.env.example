# Base URL for anx-core API (browser / client).
# Leave unset for same-origin.
PUBLIC_ANX_CORE_BASE_URL=http://127.0.0.1:8000

# Hosted: support link for error footers and help text (https:// or mailto:). Optional.
# PUBLIC_ANX_SUPPORT_URL=mailto:support@example.com

# Hosted SaaS: path to control-plane account / onboarding (browser). Default /hosted/onboarding.
# PUBLIC_ANX_HOSTED_ACCOUNT_PATH=/hosted/onboarding

# Server-side core URL used when ANX_WORKSPACES is unset (single default "local" workspace).
# ANX_CORE_BASE_URL=http://127.0.0.1:8000

# Optional workspace catalog: JSON array of { "organizationSlug", "slug", "label"?, "coreBaseUrl" }.
# Or set ANX_DEFAULT_ORGANIZATION for object-form maps that omit per-entry organizationSlug.
# Must close each object with } before the array's ]. Example (valid):
# ANX_WORKSPACES=[{"organizationSlug":"local","slug":"local","label":"Local","coreBaseUrl":"http://127.0.0.1:8000"}]

# Build-time settings for svelte.config.js can live in .env.build.
# Shell env still overrides file values for dev/build commands.

# Optional external mount prefix for the UI, for example /oar.
ANX_UI_BASE_PATH=

# Enable dev actor mode to show actor-switching and actor-creation affordances.
# When false (default), the UI hides dev-shaped identity UX suitable for hosted deployments.
# Set to "true" or "1" to enable.
ANX_DEV_ACTOR_MODE=
