# ──────────────────────────────────────────────────────────────
# OAR Hosted-v1 Production Environment
# Copy to .env and fill in values for one managed workspace deployment.
# ──────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────
# MUST be false outside local development.
# Hosted v1 expects auth on all workspace data routes. Actor-selection /
# dev-actor style workflows are development-only.
ANX_ALLOW_UNAUTHENTICATED_WRITES=false

# ── WebAuthn / Passkeys ──────────────────────────────────────
# Required for passkey auth. Set to your production domain.
# Hosted v1 does not use open public registration. Create principals through
# managed bootstrap/invite flows.
ANX_WEBAUTHN_RPID=anx.example.com
ANX_WEBAUTHN_ORIGIN=https://anx.example.com
ANX_WEBAUTHN_RP_DISPLAY_NAME=OAR

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated origins allowed for cross-origin requests.
# Only needed if web-ui is served from a different origin than core.
# When using the Docker Compose setup (web-ui proxies to core),
# this can typically be left empty.
# ANX_CORS_ALLOWED_ORIGINS=https://anx.example.com

# ── Ports (host-side mapping) ────────────────────────────────
ANX_CORE_PORT=8000
ANX_WEB_UI_PORT=3000

# Optional bind mount path for Docker Compose.
# Leave unset to use the default named Docker volume.
# HOST_ANX_WORKSPACE_ROOT=/srv/anx/team-alpha/workspace

# ── Web-UI Origin ────────────────────────────────────────────
# The public origin of the web-ui (for CSRF protection in SvelteKit).
ANX_WEB_UI_ORIGIN=https://anx.example.com

# ── Hosting model ─────────────────────────────────────────────
# Hosted v1 is one isolated workspace deployment per environment. Provisioning,
# backups, and restores are operator-managed rather than self-service.
ANX_CORE_INSTANCE_ID=team-alpha

# Required for managed bootstrap onboarding. Generate and store a real token
# before the first principal registers. Suggested: `openssl rand -hex 32`.
# The value must not contain the string "REPLACE_WITH" — hosted bootstrap
# scripts refuse to run with a placeholder token.
ANX_BOOTSTRAP_TOKEN=REPLACE_WITH_SECURE_BOOTSTRAP_TOKEN

# ── Graceful Shutdown ────────────────────────────────────────
ANX_SHUTDOWN_TIMEOUT=15s
