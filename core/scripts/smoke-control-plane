#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-18100}"
WORKSPACE_ROOT="${CONTROL_PLANE_WORKSPACE_ROOT:-$(mktemp -d "${TMPDIR:-/tmp}/oar-control-plane-smoke.XXXXXX")}"
KEEP_WORKSPACE="${KEEP_WORKSPACE:-0}"

cleanup() {
  if [[ -n "${SERVER_PID:-}" ]]; then
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
  fi
  if [[ "$KEEP_WORKSPACE" != "1" ]]; then
    rm -rf "$WORKSPACE_ROOT"
  fi
}
trap cleanup EXIT INT TERM

go run ./cmd/oar-control-plane \
  --host "$HOST" \
  --port "$PORT" \
  --workspace-root "$WORKSPACE_ROOT" \
  >/tmp/oar-control-plane-smoke.log 2>&1 &
SERVER_PID=$!

for _ in $(seq 1 30); do
  if curl -fsS "http://$HOST:$PORT/health" >/dev/null; then
    echo "control-plane smoke passed on http://$HOST:$PORT"
    exit 0
  fi
  sleep 1
done

echo >&2 "control-plane smoke failed; server log:"
cat /tmp/oar-control-plane-smoke.log >&2 || true
exit 1
