#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-8100}"
WORKSPACE_ROOT="${CONTROL_PLANE_WORKSPACE_ROOT:-$ROOT_DIR/.oar-control-plane}"

exec go run ./cmd/oar-control-plane \
  --host "$HOST" \
  --port "$PORT" \
  --workspace-root "$WORKSPACE_ROOT"
