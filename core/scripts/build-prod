#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

BIN_DIR="${BIN_DIR:-$ROOT_DIR/.bin}"
BIN_PATH="${ANX_CORE_BIN:-$BIN_DIR/anx-core}"

mkdir -p "$(dirname "$BIN_PATH")"

echo "Building anx-core → $BIN_PATH"
go build -trimpath -ldflags='-s -w' -o "$BIN_PATH" ./cmd/anx-core
echo "Build complete: $BIN_PATH"
