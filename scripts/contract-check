#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Regenerate contract artifacts and validate the working tree (Go tests, TypeScript compile).

Usage:
  ./scripts/contract-check              Regenerate + validate only
  ./scripts/contract-check --committed  Also require generated paths match Git (CI / pre-commit drift)

The default mode avoids `git diff` against the index so a successful generation is not reported as
a failure when the staging area is temporarily out of sync with the freshly regenerated files.
EOF
}

COMMITTED_CHECK=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --committed)
      COMMITTED_CHECK=true
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1 (try --help)" >&2
      exit 1
      ;;
  esac
done

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

./scripts/contract-gen

if [[ "${COMMITTED_CHECK}" == true ]]; then
  git diff --exit-code -- contracts/gen
  git diff --exit-code -- cli/internal/registry/commands.json cli/internal/registry/concepts.json cli/internal/registry/help.json cli/internal/registry/event_ref_rules.json
  git diff --exit-code -- cli/docs/generated/commands.md cli/docs/generated/command-groups.md cli/docs/generated/concepts.md cli/docs/generated/x-oar-authoring.md
  git diff --exit-code -- web-ui/src/lib/generated/event_ref_rules.json
fi

(
  cd contracts/gen/go
  go test ./...
)

pnpm exec tsc --project contracts/gen/ts/tsconfig.json --pretty false
